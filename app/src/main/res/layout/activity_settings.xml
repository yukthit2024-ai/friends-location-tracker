<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="App Configuration"
            android:textAppearance="@style/TextAppearance.AppCompat.Large"
            android:layout_marginBottom="24dp" />

        <!-- MapLibre Section -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="MapLibre Configuration"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            app:helperText="Enter a Style JSON URL (e.g. MapTiler or OSM).">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/edit_mapbox_token"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Map Style URL" />
        </com.google.android.material.textfield.TextInputLayout>

        <Button
            android:id="@+id/btn_save"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Save Configuration"
            android:backgroundTint="@color/primaryColor" />

    </LinearLayout>
</ScrollView>
